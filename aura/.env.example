# =============================================================================
# Aura — environment variables
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in the values. `.env.local` is
# git-ignored — NEVER commit real secrets.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser bundle, so
# they must NOT contain secrets.
# Vercel auto-injects NODE_ENV, VERCEL_OIDC_TOKEN and
# NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA (the version shown in the footer) — you
# don't need to set those locally.
# =============================================================================

# --- Supabase (Postgres + Auth + Realtime) -----------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=            # server-only, bypasses RLS — keep secret

# --- Web Push (VAPID, via the web-push lib) ----------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=         # same value as VAPID_PUBLIC_KEY, client side
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=                        # e.g. mailto:admin@yourdomain.com
PUSH_WEBHOOK_SECRET=                  # shared secret guarding /api/push/send/*

# --- Firebase (FCM / messaging) ----------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=                 # keep the literal \n escapes

# --- WhatsApp via Evolution API (used directly by the Next app) --------------
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# --- WhatsApp self-hosted service (the whatsapp-service/ container) -----------
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_SERVICE_URL=                 # base URL the app uses to reach the service

# --- Chatwoot (support inbox + SSO) ------------------------------------------
CHATWOOT_URL=
NEXT_PUBLIC_CHATWOOT_URL=
CHATWOOT_ACCOUNT_ID=
CHATWOOT_INBOX_ID=
CHATWOOT_API_TOKEN=
CHATWOOT_SSO_SECRET=

# --- Google Gemini (AI review summaries) -------------------------------------
GEMINI_API_KEY=

# --- Vercel Blob (image / file uploads) --------------------------------------
BLOB_READ_WRITE_TOKEN=

# --- Cron (Vercel Cron authentication) ---------------------------------------
CRON_SECRET=                          # required header for /api/cron/* in prod

# --- Scripts / optional ------------------------------------------------------
PROPERTY_ID=                          # default property id for seed/dev scripts

# -----------------------------------------------------------------------------
# The whatsapp-service/ container has its own runtime vars (PORT, SERVER_URL,
# WEBHOOK_URL, STATUS_WEBHOOK_URL, CHROME_BIN, WHATSAPP_API_KEY, PROPERTY_ID).
# See docs/DEPLOYMENT.md.
# -----------------------------------------------------------------------------
